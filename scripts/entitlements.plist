<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Minimal hardened-runtime entitlements.

  The package script signs every bundled dylib/framework with the same identity
  as the app, so we do NOT need:
    - com.apple.security.cs.disable-library-validation
      (bundled dylibs are signed by the same Team ID; library validation passes)
    - com.apple.security.cs.allow-unsigned-executable-memory
      (no mapped-then-executed pages in our code path)
    - com.apple.security.cs.allow-jit
      (ONNX Runtime CPU execution provider does not JIT; enable only if CoreML
       or a similar provider that requires JIT is introduced)

  If a future dependency genuinely needs one of these, add it back with a
  comment explaining why, rather than re-enabling the whole relaxed set.
-->
<plist version="1.0">
<dict>
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
</dict>
</plist>
